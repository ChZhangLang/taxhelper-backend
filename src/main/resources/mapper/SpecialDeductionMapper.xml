<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zihao.taxhelperai.mapper.SpecialDeductionMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.zihao.taxhelperai.model.entity.SpecialDeduction">
        <id column="id" property="id" />
        <result column="userId" property="userId" />
        <result column="deductionType" property="deductionType" />
        <result column="amount" property="amount" />
        <result column="startDate" property="startDate" />
        <result column="endDate" property="endDate" />
        <result column="status" property="status" />
        <result column="createTime" property="createTime" />
        <result column="updateTime" property="updateTime" />
        <result column="isDelete" property="isDelete" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, userId, deductionType, amount, startDate, endDate, status, createTime, updateTime, isDelete
    </sql>

    <!-- 查询用户的专项附加扣除列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from special_deduction
        where userId = #{userId}
        and isDelete = 0
        order by createTime desc
    </select>

    <!-- 查询用户当前生效的专项附加扣除总额 -->
    <select id="selectCurrentDeductionAmount" resultType="java.math.BigDecimal">
        select
        IFNULL(SUM(amount), 0) as totalAmount
        from special_deduction
        where userId = #{userId}
        and isDelete = 0
        and status = 1
    </select>
</mapper>
